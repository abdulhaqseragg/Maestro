# =============================================
# Maestro - Production Environment Variables
# =============================================
# IMPORTANT: Copy this to .env.production and fill in real values
# NEVER commit .env.production to git!
# =============================================

# ── Supabase (Authentication only — if keeping Supabase Auth)
# If migrating FULLY to self-hosted PostgreSQL, leave these blank
# and update authService.ts to use your own JWT implementation.
VITE_SUPABASE_URL=https://tucejkeuhjtchwpmrlnf.supabase.co
VITE_SUPABASE_ANON_KEY=REPLACE_WITH_YOUR_ANON_KEY

# ── Backend API (your server domain)
VITE_API_BASE_URL=https://advbrandterm.com/api

# ── Google Gemini AI
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY

# ── App Config
VITE_APP_VERSION=1.0.0
VITE_CACHE_NAME=maestro-v1.0

# ── Feature Flags (Production Values)
VITE_DISABLE_LOGIN=false
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_BACKGROUND_SYNC=true
VITE_ENABLE_PUSH_NOTIFICATIONS=false
VITE_DEV_MODE=false
