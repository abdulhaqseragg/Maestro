# Environment Variables for Maestro PWA

# API Configuration (Optional - for server sync)
VITE_API_BASE_URL=https://your-api-domain.com/api
VITE_ENABLE_SYNC=false

# PWA Configuration
VITE_APP_VERSION=1.2.0
VITE_CACHE_NAME=maestro-v1.2

# Feature Flags
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_BACKGROUND_SYNC=true
VITE_ENABLE_PUSH_NOTIFICATIONS=false

# Development
VITE_DEV_MODE=true